# OpenClaw 进化版 — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ── LLM Provider（至少填一个） ──

# DeepSeek API
# 注册: https://platform.deepseek.com
DEEPSEEK_KEY=sk-your-deepseek-key-here

# UIUI API（DeepSeek 中转，国内用户推荐）
# 注册: https://uiui.ai
UIUI_KEY=sk-your-uiui-key-here

# OpenAI API（可选）
# OPENAI_KEY=sk-your-openai-key-here

# ── 模型选择 ──
# 可选: deepseek/deepseek-chat (默认) | deepseek/deepseek-reasoner
# 发票任务推荐 deepseek-chat（速度快、成本低）
PRIMARY_MODEL=deepseek/deepseek-chat

# ── 其他配置（可选） ──
# TAVILY_API_KEY=your-tavily-key
# ANSPIRE_API_KEY=your-anspire-key
