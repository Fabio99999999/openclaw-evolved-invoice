# DeepSeek API（推荐，最便宜好用的模型）
# 注册: https://platform.deepseek.com/
DEEPSEEK_KEY=sk-your-deepseek-api-key-here

# 备选 API Key（如 OpenAI，可选）
# SECONDARY_KEY=sk-your-secondary-api-key-here

# 可选：指定主模型（默认 deepseek/deepseek-chat）
# PRIMARY_MODEL=deepseek/deepseek-chat
